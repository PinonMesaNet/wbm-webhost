        {
          "_name": "article06",
          "_sourceTheme": "patientm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article06 patientm5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"color\" title=\"Image Border\" value=\"#3A001D\" name=\"imageBorder\" selected>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\">\n        <input type=\"color\" title=\"Label BG\" value=\"#fecb66\" name=\"labelBg\" condition=\"showLabel\" selected>\n        <input type=\"color\" title=\"Label Border\" value=\"#3A001D\" name=\"labelBorder\" condition=\"showLabel\" selected>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"color\" title=\"Title Shadow\" value=\"#529581\" name=\"shadowTitle\" condition=\"showTitle\" selected>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/patientm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#b97f55\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/patientm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/sam-1551-1232x924.webp\" alt=\"Mobirise Website Builder\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"content-wrapper\">\n                    <div class=\"label-wrapper\">\n                        <h4 class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label, .label-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showLabel\">\n                            Small Changes, Big Impact\n                        </h4>\n                    </div>\n                    <div class=\"title-wrapper\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Pastor Joe Lee</b></h2>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">\n                            During the summer of 1981, while mowing grass for an elderly neighbor Joe accepted Jesus as his Lord and Savior.&nbsp; For years he knew Christ died for the sins of the world, but thought if you were good everyone would go to heaven.&nbsp; It was at this time he learned that there was a personal decision to be made.</p>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            Read More\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "margin": "0 -45px",
              ".card": {
                "padding": "0 45px",
                "justify-content": "center"
              }
            },
            ".image-wrapper": {
              "padding-left": "66px",
              "@media (max-width: 1440px)": {
                "padding-left": "0"
              },
              "@media (max-width: 992px)": {
                "margin-bottom": "32px"
              },
              "& when (@reverseContent)": {
                "padding-left": "0"
              },
              "img": {
                "width": "100%",
                "height": "550px",
                "object-fit": "cover",
                "border": "2px solid @imageBorder",
                "box-shadow": "0 16px 0 @imageBorder",
                "background-color": "@imageBorder",
                "@media (max-width: 1440px)": {
                  "height": "450px"
                },
                "@media (max-width: 992px)": {
                  "height": "350px",
                  "width": "100%"
                },
                "@media (max-width: 425px)": {
                  "height": "300px"
                }
              }
            },
            ".content-wrapper": {
              "& when (@reverseContent)": {
                "padding-left": "66px",
                "@media (max-width: 1440px)": {
                  "padding-left": "0"
                }
              },
              ".label-wrapper": {
                ".mbr-label": {
                  "display": "inline-flex",
                  "padding": "6px 20px",
                  "border": "2px solid @labelBorder",
                  "background-color": "@labelBg",
                  "margin-bottom": "22px"
                }
              },
              ".title-wrapper": {
                ".mbr-section-title": {
                  "margin-bottom": "22px",
                  "text-shadow": "0 5px 0 @shadowTitle"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "margin-bottom": "12px"
                }
              },
              ".mbr-section-btn": {
                ".btn": {
                  "margin-bottom": "0"
                }
              }
            },
            ".mbr-label": {
              "color": "#3a001d"
            },
            ".mbr-section-title": {
              "color": "#fffaf0"
            },
            ".mbr-text": {
              "color": "#fffaf0"
            }
          },
