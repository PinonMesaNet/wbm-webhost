o=\"5\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\">\n                                                        <b>SMALL GROUPS</b>\n                                                    </h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/20191208-133859-1000x1000.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"6\" data-bs-slide-to=\"6\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\">\n                                                        <b>SMALL GROUPS</b>\n                                                    </h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/00720song20time-700x340.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"7\" data-bs-slide-to=\"7\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\">\n                                                        <b>GIVING</b>\n                                                    </h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div>\n                            <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/img-6111-311x233.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"8\" data-bs-slide-to=\"8\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\"><b>Ladies Bible Study</b></h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/img-78-311x311.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"9\" data-bs-slide-to=\"9\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\"><b>Ladies Bible Study</b></h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/20191208-134158-311x311.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"10\" data-bs-slide-to=\"10\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\"><b>Ladies Bible Study</b></h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div><div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'rem', 'margin-right': gap + 'rem'}\">\n                                <a href=\"#\">\n                                    <div class=\"card-wrap\">\n                                        <div class=\"item-wrapper position-relative\">\n                                            <div class=\"image-wrap\">\n                                                <img src=\"@PROJECT_PATH@/assets/images/img-433-311x311.webp\" alt=\"Mobirise Website Builder\" data-slide-to=\"11\" data-bs-slide-to=\"11\">\n                                                <div class=\"content-wrap\">\n                                                    <h5 class=\"mbr-box mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showBox\" data-app-selector=\".mbr-box\">\n                                                        <b>C</b>\n                                                    </h5>\n                                                    <h4 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .image-wrap\"><b>Ladies Bible Study</b></h4>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                    <button class=\"embla__button embla__button--prev\">\n                        <span class=\"mbr-iconfont mobi-mbri-left mobi-mbri\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden\">Previous</span>\n                    </button>\n                    <button class=\"embla__button embla__button--next\">\n                        <span class=\"mbr-iconfont mobi-mbri-right mobi-mbri\" aria-hidden=\"true\"></span>\n                        <span class=\"sr-only visually-hidden visually-hidden\">Next</span>\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vb3bODtTvW",
          "_anchor": "slider1-19",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0",
                "@media (max-width: 992px)": {
                  "padding": "0"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0"
              }
            },
            ".row": {
              "margin": "0"
            },
            ".card": {
              "padding": "0",
              ".image-wrapper": {
                "display": "flex",
                "align-items": "center",
                "height": "100%",
                "img": {
                  "height": "740px",
                  "object-fit": "cover",
                  "@media (max-width: 992px)": {
                    "height": "300px"
                  }
                }
              },
              ".images-wrapper": {
                "display": "flex",
                "flex-direction": "column",
                "justify-content": "center",
                "height": "100%",
                ".images-wrap": {
                  "img": {
                    "height": "280px",
                    "object-fit": "cover"
                  }
                }
              },
              ".title-wrapper": {
                "padding": "0 150px",
                ".mbr-section-title": {
                  "margin-bottom": "30px"
                },
                ".mbr-text": {
                  "margin-bottom": "40px"
                },
                "@media (max-width: 1200px)": {
                  "padding": "0 90px"
                },
                "@media (max-width: 992px)": {
                  "padding": "40px 16px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#263a5c"
            },
            ".mbr-text": {
              "color": "#263652"
            }
          },
          "_name": "content3",
          "_sourceTheme": "churchm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content3 churchm5\" group=\"Content\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"range\" inline title=\"Images Amount\" name=\"cards\" min=\"0\" max=\"3\" step=\"1\" value=\"3\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#e0ae8a\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-3 card\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/100-4184-918x689.webp\" alt=\"Mobirise\" mbr-if=\"cards > 0\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-3 card\">\n                <div class=\"images-wrapper\">\n                    <div class=\"images-wrap\">\n                        <img src=\"@PROJECT_PATH@/assets/images/20180615-101841-918x446.webp\" alt=\"Mobirise\" mbr-if=\"cards > 1\">\n                        <img src=\"@PROJECT_PATH@/assets/images/20220620-155211-918x918.webp\" alt=\"Mobirise\" mbr-if=\"cards > 2\">\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"title-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Whispering&nbsp;Cedars</b><br><b>Summer Camp &amp;</b><br><b>Church Camp</b></h2>\n                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                        Our camp ministry started back in the 1960’s&nbsp; where&nbsp; we have 5 days set apart minister to the young people from the grades of 3 to 12th.&nbsp; We teach them how to know and serve the God of the Bible, enjoy building relationships through fun activities, and sing loud praises to our great God while shower them with Christ’s love.&nbsp; Some campers receive the Lord as their Savior or commit themselves to a more faithful walk with Him. We still hear testimonies of older people who got saved at church and the camp ministry many years ago.</p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\">\n                        <a class=\"btn btn-primary-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                            READ MORE\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vcLI7MO4EN",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "content3-1e"
        },
        {
          "_name": "video01",
          "_sourceTheme": "rangem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"video01\" group=\"Image & Video\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline name=\"videoWidth\" title=\"Video\" min=\"4\" max=\"8\" step=\"1\" value=\"8\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n\t\t<input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n\t\t<input type=\"checkbox\" title=\"Card\" name=\"showCard\">\n\t\t<input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n\t\t<input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n\t\t<input type=\"color\" title=\"Color\" name=\"borderColor\" value=\"#263a5c\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/image3-1224x918.webp\" parallax selected>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#263a5c\">\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n\t\t</fieldset>\n\t\t<header condition=\"bg.type === 'video'\">Fallback Image</header>\n\t\t<input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/rangem5/components/_images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n\t</mbr-parameters>\n\n\t<div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<div class=\"col-12\">\n\t\t\t\t<div class=\"title-wrapper\">\n\t\t\t\t\t<div class=\"row \">\n\t\t\t\t\t\t<h3 class=\"mbr-section-title mbr-fonts-style mb-4 col-12 col-lg-7\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\"><b>&nbsp;Our Ministries</b></h3>\n\t\t\t\t\t\t<p class=\"mbr-text ms-auto mb-4 col-12 col-lg-5 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-text\">\n\t\t\t\t\t\t\tWe work closely with our clients to know their objectives, target audience, unique needs,\n\t\t\t\t\t\t\tand practical\n\t\t\t\t\t\t\tdesign solutions.\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"col-12 col-lg-{{videoWidth}}\">\n\t\t\t\t<div mbr-video class=\"mbr-figure\">\n\t\t\t\t\t<iframe src=\"https://vimeo.com/1164490902?fl=ip&fe=ec&loop=1&autoplay=1\"></iframe>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div class=\"col-12 col-md-6 col-lg-4\" mbr-if=\"showCard\">\n\t\t\t\t<div class=\"text-wrapper\">\n\t\t\t\t\t<div class=\"card p-4 text-center\">\n\t\t\t\t\t\t<ul class=\"list-unstyled mb-0\">\n\t\t\t\t\t\t\t<li class=\"pb-4 border-bottom border-secondary\">\n\t\t\t\t\t\t\t\t<h3 class=\"mbr-card-title mbr-fonts-style mt-0 mbr-number\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t<b>15+</b>\n\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t\t\tYears of experience\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"py-4 border-bottom border-secondary\">\n\t\t\t\t\t\t\t\t<h3 class=\"mbr-card-title mbr-fonts-style mt-0 mbr-number\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t<b>120k</b>\n\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t\t\tSuccessful projects\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"pt-4\">\n\t\t\t\t\t\t\t\t<h3 class=\"mbr-card-title mbr-fonts-style mt-0 mbr-number\" data-app-selector=\".mbr-number\" mbr-theme-style=\"display-2\">\n\t\t\t\t\t\t\t\t\t<b>100%</b>\n\t\t\t\t\t\t\t\t</h3>\n\t\t\t\t\t\t\t\t<p class=\"card-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".card-text, .item .mbr-section-btn\" mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t\t\tClient satisfaction rate\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t</ul>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"mbr-section-btn mb-4\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t<a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Learn\n\t\t\t\t\t\t\tmore</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t</div>\n\t</div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = \"video\")": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            "@media (max-width: 992px)": {
              ".mbr-figure": {
                "margin-top": "1.5rem",
                "margin-bottom": "1.5rem"
              }
            },
            ".row": {
              "align-items": "center"
            },
            ".text-wrapper": {
              "@media (min-width: 992px)": {
                "padding": "0 2rem"
              },
              ".mbr-card-title": {
                "margin-bottom": "0.5rem"
              },
              ".py-4": {
                "padding-top": "1.5rem !important",
                "padding-bottom": "1.5rem !important"
              },
              ".pb-4": {
                "padding-bottom": "1.5rem !important"
              },
              ".pt-4": {
                "padding-top": "1.5rem !important"
              },
              ".mbr-figure iframe": {
                "width": "100%",
                "overflow": "hidden"
              }
            },
            ".app-video-wrapper": {
              "img": {
                "& when (@showBorder)": {
                  "background-color": "@borderColor",
                  "padding": "4px"
                }
              }
            },
            ".media-content, .mbr-figure": {
              "align-self": "center"
            },
            ".mbr-figure": {
              "overflow": "hidden"
            },
            ".card": {
              "background-color": "#000000",
              "& when (@showBorder)": {
                "background-color": "@borderColor",
                "padding": "4px"
              }
            },
            ".icon-title": {
              "color": "#bff747"
            },
            ".mbr-text": {
              "color": "#000000"
            },
            ".mbr-number": {
              "color": "#bff747"
            },
            ".card-text, .item .mbr-section-btn": {
              "color": "#fdfde1"
            },
            ".mbr-section-title": {
              "color": "#b35a2c"
            }
          },
